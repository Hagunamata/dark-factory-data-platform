# Copy this file to .env and adjust values as needed.
# .env is excluded from version control via .gitignore.

# ------------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------------
POSTGRES_USER=darkfactory
POSTGRES_PASSWORD=changeme_in_real_use
POSTGRES_DB=darkfactory
POSTGRES_PORT=5432

# ------------------------------------------------------------------
# Kafka
# ------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_LOGISTICS=logistics_events
KAFKA_TOPIC_HRSS=hrss_telemetry

# ------------------------------------------------------------------
# Airflow
# ------------------------------------------------------------------
AIRFLOW_UID=50000
AIRFLOW_WWW_USER_USERNAME=airflow
AIRFLOW_WWW_USER_PASSWORD=airflow

# ------------------------------------------------------------------
# Spark
# ------------------------------------------------------------------
SPARK_MASTER_URL=spark://spark-master:7077

# ------------------------------------------------------------------
# ELK
# ------------------------------------------------------------------
ELASTICSEARCH_PORT=9200
KIBANA_PORT=5601

# ------------------------------------------------------------------
# Data generation parameters
# ------------------------------------------------------------------
GENERATOR_LOGISTICS_ROWS=600000
GENERATOR_HRSS_ROWS=400000
GENERATOR_TIME_WINDOW_MONTHS=18

# ------------------------------------------------------------------
# Demo mode — compresses schedules for end-to-end testing
# ------------------------------------------------------------------
DEMO_MODE=false
DEMO_INGEST_INTERVAL_MINUTES=5
DEMO_PROCESS_INTERVAL_HOURS=1
